# ─── Database ──────────────────────────────────────────────────────────────────
# Azure Database for PostgreSQL connection string.
# Add ?sslmode=require for Azure managed PostgreSQL.
DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# ─── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys.
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# This is the same publishable key — used by Vite to embed it in the
# React bundle at BUILD TIME (not just at runtime).
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# Azure App Service sets PORT automatically. No need to set this manually
# on Azure — only needed if running locally outside Docker.
# PORT=8080
